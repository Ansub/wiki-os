# Optional vault bootstrap for first run
WIKI_ROOT=/absolute/path/to/your/wiki-vault

# Optional forced per-process override (wins over saved setup)
WIKIOS_FORCE_WIKI_ROOT=

# Optional runtime settings
PORT=5211
WIKIOS_INDEX_DB=/absolute/path/to/wiki-os.sqlite
WIKIOS_ADMIN_TOKEN=change-me
WIKIOS_DISABLE_WATCH=0
WIKIOS_OPEN_BROWSER=1

# Optional helper settings for scripts and local smoke tests
WIKIOS_BASE_URL=http://localhost:5211
WIKIOS_RESTART_COMMAND=
